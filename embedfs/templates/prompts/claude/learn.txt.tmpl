      "rule": "The rule or guideline this pattern represents",
      "confidence": 0.9,
      "frequency": 1
    }
  ],
  "updated_rules": [
    {
      "id": "rule-id",
      "name": "Rule Name",
      "pattern_ids": ["pattern-id-1", "pattern-id-2"],
      "enabled": true
    }
  ]
}

**Important**:
- Return ONLY the JSON object, no other text
- Only include patterns with confidence >= 0.7
- Categories must be one of: naming, error, structure, concurrency, testing
- Pattern IDs should be lowercase with hyphens (e.g., "error-wrapping")
